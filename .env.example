# ─────────────────────────────────────────────────────────────────
#  Deal Intelligence Agent — Environment Configuration
#  Copy this file to .env and fill in your values.
#  The app runs without API keys (mock mode) for demo purposes.
# ─────────────────────────────────────────────────────────────────

# ── LLM: Groq (required for real AI responses) ───────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# Model options:
#   llama-3.3-70b-versatile   (default, fast + smart)
#   llama-3.1-70b-versatile
#   mixtral-8x7b-32768        (longer context)
LLM_MODEL=llama-3.3-70b-versatile

# ── Memory: Hindsight by Vectorize (optional, enables persistence) ─
# Get your key at: https://hindsight.vectorize.io
# Without this key, memory is stored in-process (resets on restart)
HINDSIGHT_API_KEY=
HINDSIGHT_PIPELINE_ID=deal-intelligence-agent

# ── Twilio SMS + Voice (optional) ────────────────────────────────
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15551234567

# Public URL for Twilio voice webhooks (ngrok tunnel or production URL)
APP_BASE_URL=http://localhost:8000

# ── Email / SMTP (optional) ───────────────────────────────────────
# For Gmail: enable "App Passwords" in your Google account security settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# Set to "true" to actually send emails (default: draft only)
EMAIL_ENABLED=false
